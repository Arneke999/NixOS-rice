# hyprlock — "the Lain moment". The (dimmed) current wallpaper, a faint CRT
# shader (scanlines + soft phosphor glow, see hyprlock.frag), a clock + the
# "present day, present time" wired motif, and a pink input field as the only
# bright element. Analog texture lives HERE (and on boot) — never on the desktop.
#
# Colors are matugen-templated from the wallpaper. Edit hyprlock.conf.in, not
# the generated hyprlock.conf. Pink tracks the palette; red is pinned (urgency).

$accent = rgb({{colors.primary.default.hex_stripped}})
$text   = rgb({{colors.on_surface.default.hex_stripped}})
$muted  = rgb({{colors.outline.default.hex_stripped}})
$void   = rgb(0a0a0b)

general {
    hide_cursor = true
    ignore_empty_input = true
    # Faint CRT scanlines + glow over the whole lock output (kept subtle so text
    # stays crisp). The dimming of the wallpaper itself is done in `background`.
    screen_shader = $HOME/.config/hypr/hyprlock.frag
}

# The current desktop wallpaper, dimmed. set-wallpaper.sh keeps ~/.cache/wallpaper
# pointed at the live wallpaper, so the lock always matches the desktop. If the
# file is missing, hyprlock falls back to the near-black `color`.
background {
    monitor =
    path = $HOME/.cache/wallpaper
    color = $void
    blur_passes = 1
    blur_size = 2
    brightness = 0.42
    contrast = 0.95
    vibrancy = 0.10
}

# Clock — big, quiet.
label {
    monitor =
    text = cmd[update:1000] echo "$(date +'%H:%M')"
    color = $text
    font_size = 96
    font_family = JetBrainsMono Nerd Font
    position = 0, 170
    halign = center
    valign = center
}

# Wired motif.
label {
    monitor =
    text = present day,  present time   ]:->
    color = $muted
    font_size = 15
    font_family = JetBrainsMono Nerd Font
    position = 0, 84
    halign = center
    valign = center
}

# The one bright thing: pink input field.
input-field {
    monitor =
    size = 280, 46
    outline_thickness = 2
    dots_size = 0.22
    dots_spacing = 0.32
    dots_center = true
    rounding = 10
    outer_color = $accent
    inner_color = rgba(15, 15, 17, 0.85)
    font_color = $text
    check_color = $accent
    fail_color = rgb(ff5555)
    placeholder_text = <i>the Wired</i>
    fade_on_empty = false
    position = 0, -40
    halign = center
    valign = center
}
