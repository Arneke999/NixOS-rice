[config]

# matugen needs ABSOLUTE paths and cannot read env vars, so the installer
# (install.sh) substitutes @HOME@ with your real $HOME to produce config.toml.
# Edit this template, not the generated config.toml.

[templates.niri]
input_path = "@HOME@/nix-config/dotfiles/niri/config.kdl.in"
output_path = "@HOME@/nix-config/dotfiles/niri/config.kdl"

[templates.fuzzel]
input_path = "@HOME@/nix-config/dotfiles/fuzzel/fuzzel.ini.in"
output_path = "@HOME@/nix-config/dotfiles/fuzzel/fuzzel.ini"

[templates.swaync]
input_path = "@HOME@/nix-config/dotfiles/swaync/style.css.in"
output_path = "@HOME@/nix-config/dotfiles/swaync/style.css"

[templates.eww]
input_path = "@HOME@/nix-config/dotfiles/eww/eww.scss.in"
output_path = "@HOME@/nix-config/dotfiles/eww/eww.scss"

[templates.gtk]
input_path = "@HOME@/nix-config/dotfiles/gtk/gtk.css.in"
output_path = "@HOME@/nix-config/dotfiles/gtk/gtk.css"

[templates.kitty]
input_path = "@HOME@/nix-config/dotfiles/kitty/kitty.conf.in"
output_path = "@HOME@/nix-config/dotfiles/kitty/kitty.conf"

[templates.nvim]
input_path = "@HOME@/nix-config/dotfiles/nvim/lua/matugen-colors.lua.in"
output_path = "@HOME@/nix-config/dotfiles/nvim/lua/matugen-colors.lua"

[templates.fastfetch]
input_path = "@HOME@/nix-config/dotfiles/fastfetch/config.jsonc.in"
output_path = "@HOME@/nix-config/dotfiles/fastfetch/config.jsonc"

[templates.starship]
input_path = "@HOME@/nix-config/dotfiles/starship/starship.toml.in"
output_path = "@HOME@/nix-config/dotfiles/starship/starship.toml"
