font=JetBrainsMono Nerd Font 10
width=340
height=120
margin=10
padding=14
border-size=1
border-radius=10
icons=0
max-visible=5
default-timeout=5000
anchor=top-right

background-color=#0f0f11f2
text-color={{colors.on_surface.default.hex}}
border-color={{colors.primary.default.hex}}
progress-color=over {{colors.primary.default.hex}}26

[urgency=low]
border-color=#1e1e22
default-timeout=3000

[urgency=high]
border-color=#ff5555
border-size=2
default-timeout=0
