# ── kitty — themed from matugen ──────────────────────────────────────────────
# Generated from kitty.conf.in by matugen. Edit the .in, not this file.
# Near-black fixed background; wallpaper-derived accents (cursor/selection/links).

# Don't nag when closing a window with nothing running.
confirm_os_window_close 0

# Font
font_family      JetBrainsMono Nerd Font
bold_font        auto
italic_font      auto
bold_italic_font auto
font_size        12.0

# Feel
window_padding_width  10
cursor_shape          beam
cursor_blink_interval 0
scrollback_lines      10000
enable_audio_bell     no
background_opacity     1.0
tab_bar_edge          top
tab_bar_style         powerline

# ── Colors ───────────────────────────────────────────────────────────────────
# Background is pinned near-black (rice's fixed-background rule); text and chrome
# (cursor, selection, links, borders, tabs) track the wallpaper via matugen.
background           #0f0f11
foreground           {{colors.on_surface.default.hex}}
selection_background {{colors.primary.default.hex}}
selection_foreground #0f0f11
cursor               {{colors.primary.default.hex}}
cursor_text_color    #0f0f11
url_color            {{colors.tertiary.default.hex}}

active_border_color   {{colors.primary.default.hex}}
inactive_border_color #1e1e22

active_tab_background   {{colors.primary.default.hex}}
active_tab_foreground   #0f0f11
inactive_tab_background #16161a
inactive_tab_foreground {{colors.on_surface.default.hex}}

# 16-color ANSI palette — kept fixed and correct so shell colors (ls, git diff,
# prompts) stay readable. The wallpaper drives the chrome above, not these.
# black
color0  #1e1e22
color8  #3a3a40
# red
color1  #e06c75
color9  #ff7b86
# green
color2  #98c379
color10 #b5e090
# yellow
color3  #e5c07b
color11 #f0d495
# blue
color4  #61afef
color12 #82c0ff
# magenta
color5  #c678dd
color13 #d99bef
# cyan
color6  #56b6c2
color14 #6fd3e0
# white
color7  #c8c8ce
color15 #f0dedf
