{
    "layer": "top",
    "position": "top",
    "height": 26,
    "spacing": 0,
    "modules-left": ["niri/workspaces"],
    "modules-center": ["niri/window"],
    "modules-right": ["clock"],
    "niri/workspaces": {
        "format": "{index}"
    },
    "niri/window": {
        "format": "{title}",
        "max-length": 60,
        "separate-outputs": true
    },
    "clock": {
        "format": "{:%H:%M}",
        "tooltip-format": "<tt>{calendar}</tt>"
    }
}
