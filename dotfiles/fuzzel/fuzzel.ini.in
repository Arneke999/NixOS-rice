[main]
font=JetBrainsMono Nerd Font:size=11
icons-enabled=no
lines=8
width=32
horizontal-pad=18
vertical-pad=14
inner-pad=10

[colors]
background=0f0f11f2
text={{colors.on_surface.default.hex_stripped}}ff
prompt={{colors.tertiary.default.hex_stripped}}ff
placeholder=8a8a90ff
input=c8c8ceff
match={{colors.primary.default.hex_stripped}}ff
selection={{colors.primary.default.hex_stripped}}26
selection-text=e8e8eeff
selection-match={{colors.primary.default.hex_stripped}}ff
counter=8a8a90ff
border={{colors.secondary.default.hex_stripped}}ff

[border]
width=1
radius=12
