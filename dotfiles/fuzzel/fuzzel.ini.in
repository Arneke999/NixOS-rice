[main]
font=JetBrainsMono Nerd Font:size=11
icons-enabled=no
lines=8
width=32
horizontal-pad=18
vertical-pad=14
inner-pad=10

[colors]
background=0f0f11f2
text=c8c8ceff
prompt=8a8a90ff
input=c8c8ceff
match={{colors.primary.default.hex_stripped}}ff
selection=1e1e22ff
selection-text=e8e8eeff
selection-match={{colors.primary.default.hex_stripped}}ff
border=1e1e22ff

[border]
width=1
radius=12
