{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  "positionX": "right",
  "positionY": "top",
  "layer": "overlay",
  "control-center-layer": "top",
  "layer-shell": true,
  "cssPriority": "user",
  "control-center-margin-top": 8,
  "control-center-margin-bottom": 8,
  "control-center-margin-right": 8,
  "control-center-margin-left": 8,
  "notification-icon-size": 48,
  "notification-body-image-height": 120,
  "notification-body-image-width": 220,
  "timeout": 8,
  "timeout-low": 5,
  "timeout-critical": 0,
  "fit-to-screen": true,
  "control-center-width": 380,
  "control-center-height": 640,
  "notification-window-width": 400,
  "keyboard-shortcuts": true,
  "image-visibility": "when-available",
  "transition-time": 220,
  "hide-on-clear": false,
  "hide-on-action": true,
  "script-fail-notify": true,
  "widgets": ["title", "buttons-grid", "volume", "backlight", "mpris", "dnd", "notifications"],
  "widget-config": {
    "title": {
      "text": "Notifications",
      "clear-all-button": true,
      "button-text": "󰎟 Clear all"
    },
    "buttons-grid": {
      "actions": [
        {
          "label": "󰀝",
          "type": "toggle",
          "active": false,
          "command": "~/nix-config/dotfiles/swaync/scripts/airplane.sh toggle",
          "update-command": "~/nix-config/dotfiles/swaync/scripts/airplane.sh status"
        },
        {
          "label": "󰤨",
          "type": "toggle",
          "active": true,
          "command": "~/nix-config/dotfiles/swaync/scripts/wifi.sh toggle",
          "update-command": "~/nix-config/dotfiles/swaync/scripts/wifi.sh status"
        },
        {
          "label": "󰂯",
          "type": "toggle",
          "active": false,
          "command": "~/nix-config/dotfiles/swaync/scripts/bt.sh toggle",
          "update-command": "~/nix-config/dotfiles/swaync/scripts/bt.sh status"
        },
        {
          "label": "󰍬",
          "type": "toggle",
          "active": true,
          "command": "~/nix-config/dotfiles/swaync/scripts/mic.sh toggle",
          "update-command": "~/nix-config/dotfiles/swaync/scripts/mic.sh status"
        },
        {
          "label": "󰕾",
          "type": "toggle",
          "active": true,
          "command": "~/nix-config/dotfiles/swaync/scripts/audio.sh toggle",
          "update-command": "~/nix-config/dotfiles/swaync/scripts/audio.sh status"
        }
      ]
    },
    "volume": {
      "label": "󰕾",
      "show-per-app": false
    },
    "backlight": {
      "label": "󰃟"
    },
    "mpris": {
      "image-size": 90,
      "image-radius": 12
    },
    "dnd": {
      "text": "Do Not Disturb"
    },
    "notifications": {
      "vexpand": true
    }
  }
}
